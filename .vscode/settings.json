{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "files.encoding": "utf8",
  "task.allowAutomaticTasks": "on",
  "files.exclude": {
    "**/__pycache__": true,
    "**/tmp*": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/tmp*": true
  },
  "python.analysis.exclude": [
    "**/__pycache__",
    "**/tmp*"
  ]
}
