{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run HomeHub Runtime",
      "type": "shell",
      "command": "python",
      "args": [
        "runtime/server.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Open HomeHub In Browser",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process http://127.0.0.1:8787"
      ],
      "problemMatcher": []
    },
    {
      "label": "Import Codex Records On Folder Open",
      "type": "shell",
      "windows": {
        "command": "${workspaceFolder}\\tools\\codex-sync\\pull_codex_records.bat"
      },
      "linux": {
        "command": "${workspaceFolder}/tools/codex-sync/pull_codex_records.sh"
      },
      "osx": {
        "command": "${workspaceFolder}/tools/codex-sync/pull_codex_records.sh"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
